{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/streamChatCompletion",
        "function": {
          "functionId": "streamChatCompletion",
          "region": "us-central1"
        }
      }
    ]
  }
}
